# --- Telegram ---
# Get from @BotFather
BOT_TOKEN=123456:ABC-your-bot-token
# Group chat id where listings are posted. Add the bot to the group, then read the
# id from an update (e.g. https://api.telegram.org/bot<token>/getUpdates). Groups
# are negative, supergroups start with -100.
GROUP_CHAT_ID=-1001234567890
# Public HTTPS URL of the web app (must be HTTPS for Telegram Web Apps).
WEBAPP_URL=https://escra.kvasenko.com

# --- Storage ---
DB_PATH=escra.db

# --- OLX (olx.ua) ---
# Verify these against a live olx.ua Lviv rental listing (see README).
OLX_CITY_ID=5008
OLX_CATEGORY_ID=1760

# --- Cadence ---
SCRAPE_INTERVAL=180
PAGE_LIMIT=3
MAX_PHOTOS=5

# --- Web server (behind Caddy) ---
HOST=127.0.0.1
PORT=8000

# --- Web (browser) identities ---
# The app works both in Telegram (auth via signed initData) and in a plain
# browser. No flag: the mode is picked per request by whether initData is
# present. In a browser the page shows a role picker; the id is sent in X-User-Id.
# Set these to each person's REAL Telegram user id so browser + Telegram
# reactions count as the same person. The browser path is unsigned — see README.
USER_VESNUSHKA_ID=1001
USER_SLADKOEZHKA_ID=1002

# --- Auto-deploy ---
# Secret set on the GitHub webhook (repo Settings -> Webhooks -> Secret).
# Leave empty to disable the /github-push endpoint entirely.
GITHUB_WEBHOOK_SECRET=
DEPLOY_BRANCH=main

# --- Health-check watchdog (scripts/healthcheck.py) ---
# Real Telegram user id to DM when /health goes down or recovers. That person
# must have messaged the bot at least once first (see README). 0 disables alerts.
ALERT_CHAT_ID=0
